{
  "manifest_version": 3,
  "name": "哔哩哔哩轻量字幕助手",
  "version": "1.0.2",
  "description": "danmu.liu-qi.cn 的辅助浏览器插件，可在 B 站视频页查看、复制和下载字幕，并一键跳转 AI 分析。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "哔哩哔哩轻量字幕助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://www.bilibili.com/video/*",
    "https://api.bilibili.com/*",
    "https://*.hdslb.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/panel.css"
      ],
      "run_at": "document_end"
    }
  ]
}
